# Souz backend — production environment.
# Copy to /opt/souz-backend/config/backend.env on the VPS and fill in real values.
# chmod 600 it — this file holds credentials. It lives outside /opt/souz-backend/app
# so redeploys (which overwrite app/ in place) never touch it.

SOUZ_BACKEND_HOST=127.0.0.1
SOUZ_BACKEND_PORT=8080

# Postgres. Create the database/role beforehand; schema + Flyway migrations
# apply automatically on every backend boot.
SOUZ_BACKEND_DB_HOST=127.0.0.1
SOUZ_BACKEND_DB_PORT=5432
SOUZ_BACKEND_DB_NAME=souz
SOUZ_BACKEND_DB_USER=souz
SOUZ_BACKEND_DB_PASSWORD=change-me
SOUZ_BACKEND_DB_SCHEMA=public

# Trust boundary: nginx must overwrite X-Souz-Proxy-Auth with this exact value
# and set X-User-Id on every proxied /v1 request. Generate with:
#   openssl rand -hex 32
SOUZ_BACKEND_PROXY_TOKEN=change-me-long-random-token

# Encrypts provider API keys and other secrets at rest. Generate once with:
#   openssl rand -base64 32
# Do not rotate without a re-encryption migration plan.
SOUZ_MASTER_KEY=change-me-32-byte-random-key

# Telegram bot bindings — optional feature, off by default.
# ENABLE_BACKEND_TG_FEATURE=true
# TELEGRAM_TOKEN_ENCRYPTION_KEY=change-me
